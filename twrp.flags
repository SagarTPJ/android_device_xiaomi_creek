# Physical Partitions
/boot            emmc    /dev/block/bootdevice/by-name/boot            flags=display="Boot";backup=1;flashimg=1
/vendor_boot     emmc    /dev/block/bootdevice/by-name/vendor_boot     flags=display="Vendor Boot";backup=1;flashimg=1
/vbmeta          emmc    /dev/block/bootdevice/by-name/vbmeta          flags=display="VBMeta";backup=1;flashimg=1

# Storage
/external_sd     vfat    /dev/block/mmcblk1p1    /dev/block/mmcblk1    flags=display="MicroSD Card";storage;wipeui;removable
/usb_otg         vfat    /dev/block/sdg1         /dev/block/sdg        flags=display="USB-OTG";storage;wipeui;removable
